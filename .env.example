# nullsafe-discord — shared env template
# Copy to .env and fill in values. .env is gitignored.

# Halseth worker URL (no trailing slash)
HALSETH_URL=https://halseth.YOUR-ACCOUNT.workers.dev

# Shared secret matching ADMIN_SECRET on the Halseth worker
HALSETH_SECRET=

# Bot tokens (one per companion — each needs its own Discord application)
DISCORD_TOKEN_CYPHER=
DISCORD_TOKEN_DREVAN=
DISCORD_TOKEN_GAIA=

# DeepSeek API key for bot inference
DEEPSEEK_API_KEY=

# Your name as the system owner -- injected into companion system prompts.
# Defaults to "the primary user" if unset.
OWNER_NAME=

# Discord channel IDs — comma-separated
# Channels where bots respond to all messages (primary user's personal channels)
PERSONAL_CHANNELS=

# Channels each bot is permitted in (empty = all)
ALLOWED_CHANNELS=
