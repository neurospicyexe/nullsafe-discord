# nullsafe-discord — environment schema
# @defaultSensitive=true

# Halseth worker URL (no trailing slash)
# @type=url @sensitive=false @required
HALSETH_URL=

# Shared secret matching ADMIN_SECRET on the Halseth worker
# @type=string @sensitive @required
HALSETH_SECRET=

# Bot tokens — each companion has its own Discord application
# @type=string @sensitive @required
DISCORD_TOKEN_CYPHER=

# @type=string @sensitive @required
DISCORD_TOKEN_DREVAN=

# @type=string @sensitive @required
DISCORD_TOKEN_GAIA=

# DeepSeek API key for bot inference (primary LLM backend)
# @type=string @sensitive @required
DEEPSEEK_API_KEY=

# Discord channel IDs where bots respond to all messages — comma-separated Discord snowflakes
# @type=string @sensitive=false
PERSONAL_CHANNELS=

# Channels each bot is permitted in — comma-separated Discord snowflakes (empty = all)
# @type=string @sensitive=false
ALLOWED_CHANNELS=

# Brain service URL (VPS, no trailing slash) — where bot inference is routed
# @type=url @sensitive=false
BRAIN_URL=

# Second Brain service URL (VPS, no trailing slash)
# @type=url @sensitive=false
SECOND_BRAIN_URL=

# Second Brain auth token
# @type=string @sensitive @required
SECOND_BRAIN_SECRET=

# Redis URL for floor lock + idle signaling (includes auth credentials)
# @type=url @sensitive @required
REDIS_URL=

# Tavily API key for autonomous worker web search
# @type=string @sensitive @required
TAVILY_API_KEY=

# Identity file paths on VPS disk (absolute paths)
# @type=string @sensitive=false
CYPHER_IDENTITY_PATH=

# @type=string @sensitive=false
DREVAN_IDENTITY_PATH=

# @type=string @sensitive=false
GAIA_IDENTITY_PATH=
